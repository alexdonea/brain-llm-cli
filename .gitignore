# OS / Python cruft
.DS_Store
__pycache__/
*.pyc
.venv/
.claude/
.pytest_cache/
.ruff_cache/

# Working memory is volatile scratch (prefrontal/sensory buffer) — never commit it.
# Everything else under each agent's memory/ IS the persistent brain and stays committed:
#   episodic/ (hippocampus), semantic/ (neocortex), affect/ (amygdala + neuromods),
#   prospective/ (future intentions). Only the disposable scratchpad is ignored.
agents/*/memory/working/scratchpad.md
.memory/working/scratchpad.md
# Live-view activity log — transient signal that `live` tails to animate; rebuilt by every mind-event.
agents/*/memory/working/activations.jsonl
.memory/working/activations.jsonl

# Secrets & local tool state — never commit a folder-local brain.
.brain-llm/

# Per-agent concurrency lock — transient runtime state, never persistent brain.
agents/*/.lock

# Atomic-write temp files — orphaned only on a hard crash mid-save; never the persistent brain.
agents/*/memory/**/*.tmp

# Test/coverage artifacts.
.coverage
htmlcov/

# Semantic-search assets.
#   models/wordllama/  : the VENDORED 1.8MB tokenizer — COMMITTED (so recall is fully local & offline; the
#                        16MB weights ship inside the `wordllama` pip package). It is intentionally tracked.
#   embeddings.*       : per-agent vector cache — DERIVED, rebuilt from episodic/events.jsonl by `reindex`.
agents/*/memory/episodic/embeddings.npy
agents/*/memory/episodic/embeddings.ids.json
agents/*/memory/episodic/embeddings.*.npy
agents/*/memory/episodic/embeddings.*.ids.json
agents/*/memory/semantic/embeddings_facts.npy
agents/*/memory/semantic/embeddings_facts.ids.json
