# Telegram bridge config — copy this file to tools/telegram/.env and fill in your values.
# (the .env file is gitignored; never commit your token)
#
# 1. On Telegram, message @BotFather -> /newbot -> copy the HTTP API token below.
# 2. Send your new bot any message once (so it has an update to read).
# 3. Run:  python3 tools/telegram/telegram_bridge.py chatid   -> paste the chat id below.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
