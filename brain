#!/usr/bin/env bash
# brain — the one CLI for this project's mind. A thin shim over engine/agent.py so you can run
#   ./brain init --name "Aria" --host claude   ·   ./brain wake   ·   ./brain reset
# from the repo root instead of `python3 engine/agent.py …`.
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec env BRAIN_PROG=brain python3 "$DIR/engine/agent.py" "$@"
