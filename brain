#!/usr/bin/env bash
# brain — the one CLI for this project's mind. A thin shim over src/agent.py so you can run
#   ./brain init --name aria   ·   ./brain aria wake   ·   ./brain aria sleep
# from the repo root instead of `python3 src/agent.py …`. The agent name is a prefix: `./brain <agent> <cmd>`.
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# Prefer the project venv (full deps incl. wordllama → semantic recall ON by DEFAULT); fall back to the
# system python3 if it isn't there (recall then degrades to lexical - nothing breaks). Run ./install.sh or
# `python3 -m venv .venv && .venv/bin/pip install -r requirements.txt` to create it.
PY="$DIR/.venv/bin/python"; [ -x "$PY" ] || PY="python3"
exec env BRAIN_PROG=brain "$PY" "$DIR/src/agent.py" "$@"
